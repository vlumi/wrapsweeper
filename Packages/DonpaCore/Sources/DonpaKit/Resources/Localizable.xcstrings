    "": {},
    "—": {
      "comment": "A placeholder value for the best progress of a game.",
      "isCommentAutoGenerated": true
    },
    "%1$@, %2$lld by %3$lld, %4$lld mines remaining, %5$@": {
      "comment": "VoiceOver board summary: config, width, height, mines remaining, state. NEEDS REVIEW: ja/fi.",
