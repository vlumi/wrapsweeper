{
  "sourceLanguage": "en",
  "strings": {
    "": {},
    "—": {
      "comment": "A placeholder value for the best progress of a game.",
      "isCommentAutoGenerated": true
    },
    "%@, %lld by %lld, %lld mines remaining, %@": {
      "comment": "A label summarizing the state of a game board. The first argument is the name of the game (e.g. \"Minesweeper\"). The second and third arguments are the width and height of the game board. The fourth argument is the number of mines remaining. The fifth argument is the string “Won”, the string “Lost”, the string “In progress”, or the string “Ready”.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@, %2$lld by %3$lld, %4$lld mines remaining, %5$@"
          }
        }
      }
    },
    "%1$@, %2$lld by %3$lld, %4$lld mines remaining, %5$@": {
      "comment": "VoiceOver board summary: config, width, height, mines remaining, state. NEEDS REVIEW: ja/fi.",
      "localizations": {
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%1$@, %2$lld × %3$lld, %4$lld miinaa jäljellä, %5$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%1$@、%2$lld×%3$lld、残り地雷 %4$lld、%5$@"
          }
        }
      }
    },
    "%lld": {
      "comment": "A number of wins for a given game configuration.",
      "isCommentAutoGenerated": true
    },
    "%lld%%": {
      "comment": "A percentage.",
      "isCommentAutoGenerated": true
    },
