  "strings": {
    "%1$@, %2$lld by %3$lld, %4$lld mines remaining, %5$@": {
      "comment": "VoiceOver board summary: config, width, height, mines remaining, state. NEEDS REVIEW: ja/fi.",
      "localizations": {
        "fi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%1$@, %2$lld × %3$lld, %4$lld miinaa jäljellä, %5$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%1$@、%2$lld×%3$lld、残り地雷 %4$lld、%5$@"
          }
        }
      }
    },
    "%@, %lld by %lld, %lld mines remaining, %@": {
      "comment": "A voice-over summary of the game board. The argument is the string “Won”, the string “Lost”, the string “In progress”, or the string “Ready”.",
