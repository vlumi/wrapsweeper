# Editor
.vscode/

# macOS
.DS_Store

# Xcode / SwiftPM
.build/
DerivedData/
*.xcodeproj
*.xcworkspace
xcuserdata/
*.xcuserstate

# Generated by XcodeGen (regenerate with the project gen script)
Donpa.xcodeproj

# Coverage export (produced in CI)
coverage.lcov

# Local-only scratch (notes, brainstorms) — never committed
.local/

# Local Xcode build output (Makefile/Scripts run targets)
.build-xcode/

# Release artifacts + App Store Connect credentials (never committed).
# The .p8 key lives in ~/.appstoreconnect/private_keys/, outside the repo;
# .asc-config holds the (local) Key ID / Issuer ID.
/dist/
*.xcarchive
*.ipa
*.pkg
Scripts/.asc-config

# Perf-probe output (traces + summaries) — local only
perf-out/
